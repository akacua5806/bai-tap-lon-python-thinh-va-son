import tkinter as tk
from tkinter import messagebox
import requests
import matplotlib.pyplot as plt
import numpy as np

first_player_stats = {}
second_player_stats = {}
stat_checkboxes = {}

IGNORE_FIELDS = ['Player', 'Nation', 'Pos', 'Squad', 'Age', 'Born', 'Rk']


def fetch_player_info(p_idx, input_field, display_panel):
    query_name = input_field.get().strip()
    if not query_name:
        messagebox.showwarning("Cảnh báo", "Hãy điền tên cầu thủ cần tìm!")
        return

    try:
        api_endpoint = f"http://127.0.0.1:5000/api/player?name={query_name}"
        api_response = requests.get(api_endpoint)

        if api_response.status_code == 200:
            json_payload = api_response.json()
            stats_dict = json_payload[0]
            if p_idx == 1:
                global first_player_stats
                first_player_stats = stats_dict
            else:
                global second_player_stats
                second_player_stats = stats_dict

            for widget in display_panel.winfo_children():
                widget.destroy()

            tk.Label(display_panel, text=f"Cầu thủ: {stats_dict.get('Player', '')}", font=("Arial", 11, "bold")).pack(
                pady=2)
            tk.Label(display_panel, text=f"CLB: {stats_dict.get('Squad', 'N/A')}", fg="blue").pack(pady=2)

            grid_panel = tk.Frame(display_panel)
            grid_panel.pack(fill=tk.BOTH, expand=True, pady=5)
            r_count = 0
            c_count = 0
            ROW_LIMIT = 12

            for stat, val in stats_dict.items():
                if stat not in IGNORE_FIELDS:
                    try:
                        numeric_val = float(val) if val != '' else 0.0
                    except (ValueError, TypeError):
                        continue

                    if stat not in stat_checkboxes:
                        stat_checkboxes[stat] = tk.IntVar()

                    cb_widget = tk.Checkbutton(grid_panel, text=f"{stat}: {numeric_val}",
                                               variable=stat_checkboxes[stat])
                    cb_widget.grid(row=r_count, column=c_count, sticky='w', padx=5, pady=1)
                    r_count += 1
                    if r_count >= ROW_LIMIT:
                        r_count = 0
                        c_count += 1
        else:
            messagebox.showerror("Thông báo lỗi", f"Không tìm thấy dữ liệu cho: {query_name}")

    except requests.exceptions.RequestException as error:
        messagebox.showerror("Thất bại", "Lỗi kết nối máy chủ.\nChi tiết: " + str(error))


def generate_comparison_chart():
    chosen_metrics = [metric for metric, var in stat_checkboxes.items() if var.get() == 1]
    if not chosen_metrics:
        messagebox.showwarning("Nhắc nhở", "Vui lòng tích chọn tối thiểu một chỉ số!")
        return
    if not first_player_stats or not second_player_stats:
        messagebox.showwarning("Nhắc nhở", "Bạn cần tra cứu đủ thông tin cả 2 cầu thủ!")
        return

    chart_labels = chosen_metrics
    v1_list = [first_player_stats[m] for m in chosen_metrics]
    v2_list = [second_player_stats[m] for m in chosen_metrics]
    theta_values = np.linspace(0, 2 * np.pi, len(chosen_metrics), endpoint=False).tolist()

    v1_list += v1_list[:1]
    v2_list += v2_list[:1]
    theta_values += theta_values[:1]

    figure, polar_axis = plt.subplots(figsize=(6, 6), subplot_kw=dict(polar=True))
    polar_axis.plot(theta_values, v1_list, color='red', linewidth=2, label=first_player_stats.get('Player'))
    polar_axis.fill(theta_values, v1_list, color='red', alpha=0.25)
    polar_axis.plot(theta_values, v2_list, color='blue', linewidth=2, label=second_player_stats.get('Player'))
    polar_axis.fill(theta_values, v2_list, color='blue', alpha=0.25)
    polar_axis.set_theta_offset(np.pi / 2)
    polar_axis.set_theta_direction(-1)
    polar_axis.set_xticks(theta_values[:-1])
    polar_axis.set_xticklabels(chart_labels)

    plt.legend(loc='upper right', bbox_to_anchor=(1.3, 1.1))
    plt.show()


main_window = tk.Tk()
main_window.title("Trực quan hóa chỉ số cầu thủ Ngoại Hạng Anh")
main_window.geometry("700x500")

panel_p1 = tk.LabelFrame(main_window, text='Cầu thủ thứ 1', padx=10, pady=10)
panel_p1.pack(side=tk.LEFT, fill=tk.BOTH, expand=True, padx=10, pady=10)
txt_p1 = tk.Entry(panel_p1, width=25)
txt_p1.pack(pady=5)
content_p1 = tk.Frame(panel_p1)
content_p1.pack(fill=tk.BOTH, expand=True)
search_btn_p1 = tk.Button(panel_p1, text="Tra cứu", command=lambda: fetch_player_info(1, txt_p1, content_p1))
search_btn_p1.pack(pady=5)

panel_p2 = tk.LabelFrame(main_window, text="Cầu thủ thứ 2", padx=10, pady=10)
panel_p2.pack(side=tk.RIGHT, fill=tk.BOTH, expand=True, padx=10, pady=10)
txt_p2 = tk.Entry(panel_p2, width=25)
txt_p2.pack(pady=5)
content_p2 = tk.Frame(panel_p2)
content_p2.pack(fill=tk.BOTH, expand=True)
search_btn_p2 = tk.Button(panel_p2, text="Tra cứu", command=lambda: fetch_player_info(2, txt_p2, content_p2))
search_btn_p2.pack(pady=5)

compare_btn = tk.Button(main_window, text="So sánh ngay", font=("Arial", 12, "bold"), bg="lightblue",
                        command=generate_comparison_chart)
compare_btn.pack(side=tk.BOTTOM, pady=20)

main_window.mainloop()
