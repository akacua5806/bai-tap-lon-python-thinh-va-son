import pandas as pd
import matplotlib.pyplot as plt
from sklearn.cluster import KMeans
from sklearn.metrics import silhouette_score
from sklearn.preprocessing import StandardScaler
from sklearn.decomposition import PCA

def player_clustering():
    
    df = pd.read_csv('EPL_Players_Stats_Undetected.csv')
    
   
    text_columns = ['STT', 'Player', 'Nation', 'Pos', 'Squad', 'Age', 'Born', 'Matches']
    numeric_cols = [col for col in df.columns if col not in text_columns]
    
  
    X = df[numeric_cols].apply(pd.to_numeric, errors='coerce').fillna(0)

   
    scaler = StandardScaler()
    X_scaled = scaler.fit_transform(X)

   
    k_range = range(2, 11)
    inertia = []
    silhouette_scores = []

    print("Đang tính toán Elbow và Silhouette...")
    for k in k_range:
        kmeans = KMeans(n_clusters=k, random_state=42, n_init=10)
        kmeans.fit(X_scaled)
        inertia.append(kmeans.inertia_)
        silhouette_scores.append(silhouette_score(X_scaled, kmeans.labels_))

   
    plt.figure(figsize=(8, 5))
    plt.plot(k_range, inertia, marker='o', linestyle='--', color='blue')
    plt.title('Phương pháp Elbow')
    plt.xlabel('Số lượng cụm (K)')
    plt.ylabel('Inertia')
    plt.grid(True)
    plt.savefig('Elbow_Chart.png')
    plt.close()

   
    plt.figure(figsize=(8, 5))
    plt.plot(k_range, silhouette_scores, marker='o', linestyle='--', color='orange')
    plt.title('Phương pháp Silhouette')
    plt.xlabel('Số lượng cụm (K)')
    plt.ylabel('Silhouette Score')
    plt.grid(True)
    plt.savefig('Silhouette_Chart.png')
    plt.close()

    
    best_k = 4
    kmeans = KMeans(n_clusters=best_k, random_state=42, n_init=10)
    df['Cluster'] = kmeans.fit_predict(X_scaled)
    print(f"Đã phân cầu thủ thành {best_k} nhóm.")

   
    pca_2d = PCA(n_components=2)
    X_pca_2d = pca_2d.fit_transform(X_scaled)
    
    plt.figure(figsize=(10, 8))
    scatter = plt.scatter(X_pca_2d[:, 0], X_pca_2d[:, 1], c=df['Cluster'], cmap='viridis', alpha=0.7, edgecolors='k')
    plt.title('Scatter Plot 2D (Phân nhóm cầu thủ)')
    plt.xlabel('Thành phần chính 1 (PC1)')
    plt.ylabel('Thành phần chính 2 (PC2)')
    plt.colorbar(scatter, label='Cluster')
    plt.grid(True)
    plt.savefig('PCA_2D.png')
   

   
    pca_3d = PCA(n_components=3)
    X_pca_3d = pca_3d.fit_transform(X_scaled)

    fig = plt.figure(figsize=(12, 9))
    ax = fig.add_subplot(111, projection='3d')
    scatter3d = ax.scatter(X_pca_3d[:, 0], X_pca_3d[:, 1], X_pca_3d[:, 2], c=df['Cluster'], cmap='viridis', alpha=0.7, edgecolors='k')
    ax.set_title('Scatter Plot 3D (Phân nhóm cầu thủ)')
    ax.set_xlabel('PC1')
    ax.set_ylabel('PC2')
    ax.set_zlabel('PC3')
    fig.colorbar(scatter3d, label='Cluster')
    plt.savefig('PCA_3D.png')
    

    print("Hoàn tất! Các biểu đồ đã được lưu vào thư mục.")
    plt.show()
if __name__ == "__main__":
    player_clustering()
